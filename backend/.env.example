# Server
PORT=4000

# MySQL Database (use DB_* / MYSQL_* or DATABASE_URL — see src/lib/db.ts)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ondm

# If you start MySQL with `docker compose up -d ondm-mysql`, match compose defaults (docker-compose.yml):
# DATABASE_URL="mysql://ondm:ondm_secure_pass_2024@localhost:3306/ondm"
# Or use root with MYSQL_ROOT_PASSWORD default: mysql://root:ondm_root_secure_2024@localhost:3306/ondm

# Or DATABASE_URL directly (must start with mysql://)
# DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME"

# CORS
FRONTEND_URL="http://localhost:3000,http://localhost:3001"

# Auth
JWT_SECRET=your-secret-key-change-in-production
