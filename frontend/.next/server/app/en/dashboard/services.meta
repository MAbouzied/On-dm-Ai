{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/dashboard/layout,_N_T_/[locale]/dashboard/services/layout,_N_T_/[locale]/dashboard/services/page,_N_T_/en/dashboard/services"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/dashboard/services/__PAGE__",
    "/$d$locale/dashboard/services",
    "/$d$locale/dashboard",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}