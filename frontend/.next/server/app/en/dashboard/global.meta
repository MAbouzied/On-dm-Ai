{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/dashboard/layout,_N_T_/[locale]/dashboard/global/layout,_N_T_/[locale]/dashboard/global/page,_N_T_/en/dashboard/global"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/dashboard/global/__PAGE__",
    "/$d$locale/dashboard/global",
    "/$d$locale/dashboard",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}