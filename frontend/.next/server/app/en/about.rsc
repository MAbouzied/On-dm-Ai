19:["$","$L1a",null,{"children":[["$","$L1b",null,{}],["$","$L1c",null,{"children":["$","$L1d",null,{"siteConfig":{"hero.titleEn":"Build. Launch. Grow. Everything your digital business needs","hero.titleAr":"ابنِ. أطلق. نمُ. كل ما تحتاجه أعمالك الرقمية","hero.subtitleEn":"Websites, apps, and digital marketing that level up your business.","hero.subtitleAr":"مواقع وتطبيقات وتسويق رقمي يرفع مستوى أعمالك.","hero.badge1En":"We Build What Brands Dream","hero.badge2En":"Data_Driven Decision Making","ourStory.mainTextEn":"Since 2017, ON DM has been a trusted digital solutions agency serving Egypt, Saudi Arabia, and the UAE. We use the latest strategies and data-driven insights to help businesses build a strong online presence, create impactful content, and run marketing campaigns that deliver real results.Whether your goal is to grow your brand, boost sales, or improve customer experience, our expert team turns your dream into success.\n","ourStory.mainTextAr":"منذ عام 2017، كانت ON DM وكالة حلول رقمية موثوقة تخدم مصر والمملكة العربية السعودية والإمارات العربية المتحدة. نستخدم أحدث الاستراتيجيات والرؤى المستندة إلى البيانات لمساعدة الشركات على بناء حضور قوي عبر الإنترنت، وإنشاء محتوى مؤثر، وإدارة حملات تسويقية تحقق نتائج حقيقية. سواء كان هدفك هو تنمية علامتك التجارية، أو زيادة المبيعات، أو تحسين تجربة العملاء، فإن فريق خبرائنا يحول حلمك إلى نجاح.سواء كان هدفك هو تنمية علامتك التجارية، أو زيادة المبيعات، أو تحسين تجربة العملاء، فإن فريق خبرائنا يحول حلمك إلى نجاح.\n","ourStory.stats.years":"7+","ourStory.stats.employees":"30+","ourStory.stats.products":"42+","clients":"[{\"name\":\"Tfaseel\",\"logo\":\"/Tfaseel.svg\",\"url\":\"https://tfaseel.com/\"},{\"name\":\"Bubbles\",\"logo\":\"/Bubbles.svg\",\"url\":\"https://bubbleskidswear.com/\"},{\"name\":\"3abq\",\"logo\":\"/3abq.svg\",\"url\":\"https://web.3baq.com.sa/\"},{\"name\":\"Wessam El-Shutter\",\"logo\":\"/Wessam-el-shutter.svg\",\"url\":\"https://sa.el-shutter.com/\"}]","contact.titleEn":"Contact us","contact.titleAr":