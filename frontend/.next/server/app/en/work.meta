{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/work/layout,_N_T_/[locale]/work/page,_N_T_/en/work"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/work/__PAGE__",
    "/$d$locale/work",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}