{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/dashboard/layout,_N_T_/[locale]/dashboard/contact/layout,_N_T_/[locale]/dashboard/contact/page,_N_T_/ar/dashboard/contact"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/dashboard/contact/__PAGE__",
    "/$d$locale/dashboard/contact",
    "/$d$locale/dashboard",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}